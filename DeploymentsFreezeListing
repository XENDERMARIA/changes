                                                        <span className='data-type1' style={{ fontWeight: "var(--font-weight-500)", color: "var(--color-content-secondary)" }}>View Freezing Details</span>
                                                        <span className='ri-arrow-down-s-line line-height-normal' style={{ fontSize: "var(--font-20)" }}></span>
                                                    </div>
                                            }
                                        </div>
                                    )
                                })
                                :
                                <BlankPage
                                    pageIcon={<span className='ri-apps-line font-28 text-anchor-blue'></span>}
                                    text={"You have no change freeze added"}
                                    primaryButton={
                                        {
                                            actionType: 'link',
                                            action: "/change-freeze/add",
                                            icon: <span className="ri-add-line font-14"></span>,
                                            text: 'Create',
                                            buttonClass: 'btn-primary m-auto'
                                        }
                                    }
                                    type="deployment-freeze"
                                />
                    }
                </div>
                {
                    state.freeze_list && state.freeze_list.length > 0 &&
                    <div className="pagination-container">
                        <PaginationTwo
                            current_page_count={state.curr_page}
                            total_count={state.total_page}
                            count={state.count}
                            next={state.next}
                            previous={state.previous}
                            on_previous_click={() => {
                                fetchFreezeListingPrev(state.previous)
                            }}
                            on_next_click={() => {
                                fetchFreezeListingNext(state.next);
                            }}
                            on_pageNumber_click={(pageNumber) => {
                                fetchFreezeListingPage(pageNumber);
                            }}
                        />
                    </div>

                }
            </DeploymentsFreezeListView>
        </>
    )
}

