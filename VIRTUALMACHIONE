export default function VirtualMachineStatus() {
  const classes = useStyles();
  const { vm_group_id } = useParams();
  const { id } = useParams();
  const history = useNavigate();
  const location = useLocation();
  const { showSnackbar } = useCustomSnackbar();
  const [editedItem, setEditedItem] = useState(null);

  const [fetchKeyDialogState, setFetchKeyDialogState] = useState({
    open: false,
    user_name: "",    // ← was vm_name
    ip_address: "",
  });

  // Default filters that are always visible
  const defaultFilters = ["vm_name", "primary_tag", "ip_address"];

  const safeAccess = (obj, path, defaultValue = null) => {
    return path.split('.').reduce((acc, part) => acc?.[part], obj) ?? defaultValue;
  };

  const safeArray = (value) => Array.isArray(value) ? value : [];
  const navigate = useNavigate();

  const [state, setState] = useState({
    data: {},
    error: {},
    master_envs_list: [],
    selectedMasterEnv: [],
    parent_state: null,
    vm_arr: [],
    validations: {},
    curr_page: 1,
    total_page: 0,
    count: 0,
    next: null,
    previous: null,
    loading_vms: true,
    edit_state_loading: false,
    env_data_loading: false,
    moreAdvFilterList: defaultFilters,
    advFilters: {
      vm_name: [],
      primary_tag: [],
      secondary_tag: [],
      ip_address: [],
      status: [],
    },
    resetCount: 0,
    is_filters_applied: false,
    singleVmChildState: null,
  });

  console.log("state", state.data);
  useEffect(() => {
    if (id) {
      fetchVMGroupDataAndSetState(id);
    }
  }, [id]);

  useEffect(() => {
    resetAdvFilter();
  }, [location.pathname]);

  useEffect(() => {
    isFiltersApplied();
  }, [state.advFilters]);

  useEffect(() => {
    if (state?.data?.environment_master_type && state?.master_envs_list) {
      try {
        const envTypes = safeArray(state.data.environment_master_type);
        const envList = safeArray(state.master_envs_list);

        const filteredEnvs = envList.filter((item) =>
          envTypes.includes(item?.order),
        );

        setState((new_state) => ({
          ...new_state,
          selectedMasterEnv: filteredEnvs,
        }));
      } catch (error) {
        console.error("Error filtering environments:", error);
      }
    }
  }, [state.master_envs_list, state.data.environment_master_type]);

  useEffect(() => {
    fetchMasterEnvList();
  }, []);

  // Load filters from URL on mount

  useEffect(() => {
    try {
      const urlSearchParams = new URLSearchParams(location.search);

      if (urlSearchParams.size !== 0) {
        let moreAdvFilter = [...defaultFilters];
        let advFilters = {};

        urlSearchParams.forEach((value, key) => {
          if (!value) return;

          try {
            if (key === "adv_search") {
              const updatedList = value.split(",").filter(Boolean);
              moreAdvFilter = [...new Set([...moreAdvFilter, ...updatedList])];
            } else if (!["limit", "offset"].includes(key)) {
              advFilters[key] = value.split(",").filter(Boolean);
            }
          } catch (err) {
            console.error(`Error parsing URL param ${key}:`, err);
          }
        });

        setState((prevState) => ({
          ...prevState,
          moreAdvFilterList: moreAdvFilter,
          advFilters: {
            ...prevState.advFilters,
            ...advFilters,
          },
        }));

        if (id) {
          fetchVMsWithFilters(id, 1, advFilters, moreAdvFilter);
        }
      } else if (id) {
        fetchVmOfVMGroups(id, 1);
      }
    } catch (error) {
      console.error("Error parsing URL parameters:", error);
      if (id) {
        fetchVmOfVMGroups(id, 1);
      }
    }
  }, [id, location.search]);

  const [openCSVDialog, setOpenCSVDialog] = useState(false);
  const [open, setOpen] = useState({ open: false, clear_form_flag: false });
  const [openHealthDialog, setOpenHealthDialog] = useState(false);
  const [selectedVMForHealth, setSelectedVMForHealth] = useState(null);
  const [taskId, setTaskId] = useState(null);

  const handleClickOpen = (doClearForm) => {
    setEditedItem(null);
    setState((prev) => ({ ...prev, singleVmChildState: null }));
    setOpen((prev_state) => ({
      ...prev_state,
      open: true,
      clear_form_flag: doClearForm,
    }));
  };

  const handleClickClose = () => {
    setOpen((prev_state) => ({
      ...prev_state,
      open: false,
    }));
  };
  const getDataAndSetToState = (data) => { };
  const handleCloseDialogAndFetchVMs = () => {
    console.log(state.parent_state, "jkdjsjfadfjka");
    if (state.parent_state && state.parent_state.id) {
      fetchVmGroups(state.parent_state.id);
    }
    setState((new_state) => ({
      ...new_state,
      selectedTab: 2,
      data: {},
      error: {},
    }));
  };

  const handleClickSSHKeyDialog = () => {
    handleClickClose();
  };

  const fetchVmGroups = (id) => {
    var requestInfo = {
      endPoint: GenerateURL(
        { edit_id: id },
        properties.api.edit_vm_group + "?vm_sets=true",
      ),
      httpMethod: "GET",
      httpHeaders: { "Content-Type": "application/json" },
    };

    InvokeApi(
      requestInfo,
      fetchVMGroupDataAndSuccess,
      fetchVMGroupDataAndFailed,
    );
    setState((new_state) => ({
      ...new_state,
      loading_vms: true,
    }));
  };

  const fetchVmOfVMGroups = (id, pageNumber = 1) => {
    setState((new_state) => ({
      ...new_state,
      loading_vms: true,
    }));

    const limit = 6;
    const offset = (pageNumber - 1) * limit;

    var requestInfo = {
      endPoint: GenerateURL(
        { edit_id: id },
        properties.api.edit_vm_group + `?vm_sets=true`,
      ),
      httpMethod: "GET",
      httpHeaders: { "Content-Type": "application/json" },
    };

    InvokeApi(
      requestInfo,
      (data) => fetchVMGroupDataAndSuccess(data, pageNumber),
      fetchVMGroupDataAndFailed,
    );
  };

  const fetchVMsWithFilters = (
    id,
    pageNumber = 1,
    filters = null,
    activeFilters = null,
  ) => {
    setState((new_state) => ({
      ...new_state,
      loading_vms: true,
    }));

    const limit = 6;
    const offset = (pageNumber - 1) * limit;

    const baseURL = GenerateURL(
      { edit_id: id },
      properties.api.edit_vm_group + `?vm_sets=true`,
    );

    const filtersToUse = filters || state.advFilters;
    const activeFiltersToUse = activeFilters || state.moreAdvFilterList;

    const resultURL = generateFilterURL(
      baseURL,
      filtersToUse,
      activeFiltersToUse,
    );

    var requestInfo = {
      endPoint: resultURL,
      httpMethod: "GET",
      httpHeaders: { "Content-Type": "application/json" },
    };

    InvokeApi(
      requestInfo,
      (data) => fetchVMGroupDataAndSuccess(data, pageNumber),
      fetchVMGroupDataAndFailed,
    );
  };

  // Generate URL with filters
  const generateFilterURL = (baseURL, listDict, activeFilters) => {
    try {
      if (!baseURL) return "";

      let searchParams = new URLSearchParams();

      // Extract existing params from baseURL if it has query string
      if (baseURL.includes("?")) {
        const [url, queryString] = baseURL.split("?");
        const existingParams = new URLSearchParams(queryString);
        existingParams.forEach((value, key) => {
          searchParams.append(key, value);
        });
        baseURL = url;
      }

      // Add filter params with null checks
      const filtersKeyArray = Object.keys(listDict || {});
      filtersKeyArray.forEach((key) => {
        try {
          const arrayFilterValues = safeArray(listDict[key]);
          if (
            arrayFilterValues.length > 0 &&
            isFilterActive(key, activeFilters)
          ) {
            const arrayString = arrayFilterValues.join(",");
            searchParams.set(key, arrayString);
          }
        } catch (err) {
          console.error(`Error processing filter ${key}:`, err);
        }
      });

      const queryString = searchParams.toString();
      return queryString ? `${baseURL}?${queryString}` : baseURL;
    } catch (error) {
      console.error("Error generating filter URL:", error);
      return baseURL || "";
    }
  };

  const isFilterActive = (filterKey, list) => {
    return safeArray(list).find((name) => filterKey === name);
  };

  function isFiltersApplied() {
    try {
      let count = 0;
      const filters = state?.advFilters || {};

      Object.keys(filters).forEach((item) => {
        if (safeArray(filters[item]).length > 0) {
          count = count + 1;
        }
      });

      setState((new_state) => ({
        ...new_state,
        is_filters_applied: count > 0,
      }));
    } catch (error) {
      console.error("Error checking filters:", error);
    }
  }

  const fetchVMGroupDataAndSuccess = (data, currentPage) => {
    try {
      // Safely access nested data
      const vmArray = data?.results || data || [];
      const totalCount =
        data?.count ?? (Array.isArray(vmArray) ? vmArray.length : 0);

      // Ensure vmArray is always an array
      const validVmArray = Array.isArray(vmArray) ? vmArray : [];

      setState((new_state) => ({
        ...new_state,
        vm_arr: validVmArray,
        loading_vms: false,
        curr_page: currentPage || 1,
        total_page: Math.ceil(totalCount / 6) || 0,
        count: totalCount,
        next: data?.next || null,
        previous: data?.previous || null,
      }));
    } catch (error) {
      console.error("Error processing VM data:", error);
      showSnackbar("Error processing VM data", "error");
      setState((new_state) => ({
        ...new_state,
        vm_arr: [],
        loading_vms: false,
      }));
    }
  };

  const fetchVMGroupDataAndFailed = (error) => {
    showSnackbar(error?.message || "Failed to fetch VM data", "error");
    setState((new_state) => ({
      ...new_state,
      error_vm_arr: error?.message || "Failed to fetch VM data",
      loading_vms: false,
    }));
  };

  const fetchVMGroupDataAndSetState = (id) => {
    setState((new_state) => ({
      ...new_state,
      edit_state_loading: true,
    }));

    var requestInfo = {
      endPoint: GenerateURL({ edit_id: id }, properties.api.edit_vm_group),
      httpMethod: "GET",
      httpHeaders: { "Content-Type": "application/json" },
    };

    InvokeApi(
      requestInfo,
      fetchVMGroupDataAndSetStateSuccess,
      fetchVMGroupDataAndSetStateFailed,
    );
  };

  const fetchVMGroupDataAndSetStateSuccess = (data) => {
    try {
      setState((new_state) => ({
        ...new_state,
        edit_state_loading: false,
        parent_state: data || {},
        data: {
          ...new_state.data,
          ...(data || {}),
        },
      }));
    } catch (error) {
      console.error("Error setting VM group data:", error);
      showSnackbar("Error processing VM group data", "error");
      setState((new_state) => ({
        ...new_state,
        edit_state_loading: false,
      }));
    }
  };

  const fetchVMGroupDataAndSetStateFailed = (error) => {
    showSnackbar(error?.message || "Failed to fetch VM group data", "error");
    setState((new_state) => ({
      ...new_state,
      edit_state_loading: false,
      error_msg: error?.message || "Failed to fetch VM group data",
    }));
  };

  function fetchMasterEnvList() {
    setState((new_state) => ({
      ...new_state,
      env_data_loading: true,
    }));

    var requestInfo = {
      endPoint: GenerateURL({}, properties.api.master_envs),
      httpMethod: "GET",
      httpHeaders: { "Content-Type": "application/json" },
    };

    InvokeApi(
      requestInfo,
      fetchMasterEnvListDataSuccess,
      fetchMasterEnvListDataFailed,
    );
  }

  function fetchMasterEnvListDataSuccess(data) {
    try {
      const envList = safeArray(data).map((item) => ({
        tabName: item?.name || "Unknown",
        order: item?.id || 0,
      }));

      setState((new_state) => ({
        ...new_state,
        master_envs_list: envList,
        env_data_loading: false,
      }));
    } catch (error) {
      console.error("Error processing master env list:", error);
      showSnackbar("Error processing environment data", "error");
      setState((new_state) => ({
        ...new_state,
        master_envs_list: [],
        env_data_loading: false,
      }));
    }
  }

  function fetchMasterEnvListDataFailed(error) {
    showSnackbar(
