  // Add filters to URL
  const addFiltersToUrl = (filterName, filterValue) => {
    try {
      let urlSearchParams = new URLSearchParams(location.search);
      const allFilters = [
        "vm_name",
        "primary_tag",
        "secondary_tag",
        "ip_address",
        "status",
      ];

      if (filterName === "all_delete") {
        urlSearchParams = new URLSearchParams();
      } else {
        const safeFilterValue = safeArray(filterValue);

        if (filterName === "adv_search") {
          allFilters.forEach((value) => {
            if (!safeFilterValue.includes(value)) {
              urlSearchParams.delete(value);
            }
          });
        }

        if (safeFilterValue.length === 0) {
          urlSearchParams.delete(filterName);
        } else {
          const valueString = safeFilterValue.join(",");
          if (urlSearchParams.has(filterName)) {
            urlSearchParams.set(filterName, valueString);
          } else {
            urlSearchParams.append(filterName, valueString);
          }
        }
      }

      history({
        pathname: location.pathname,
        search: urlSearchParams.toString(),
      });
    } catch (error) {
      console.error("Error updating URL filters:", error);
    }
  };

