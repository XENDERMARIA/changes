                                          maxWidth: "var(--space-100)",
                                          textAlign: "center",
                                        }}
                                      >
                                        {tag}
                                      </span>
                                    ))}
                                </div>
                              }
                              arrow
                              placement="top"
                              componentsProps={{
                                tooltip: {
                                  sx: {
                                    bgcolor: "var(--color-white) !important",
                                    backgroundColor: "var(--color-white) !important",
                                    // border: 'var(--space-1) solid var(--color-badge-grey-bg) !important',
                                    boxShadow: "var(--space-0) var(--space-4) var(--space-12) rgba(0, 0, 0, 0.1) !important",
                                    borderRadius: "var(--radius-8) !important",
                                    maxWidth: "var(--space-400) !important",
                                    padding: "var(--space-4) !important",
                                  },
                                },
                                arrow: {
                                  sx: {
                                    color: "var(--color-white) !important",
                                    "&::before": {
                                      // border: 'var(--space-1) solid var(--color-badge-grey-bg) !important',
                                      backgroundColor: "var(--color-white) !important",
                                      boxSizing: "border-box",
                                    },
                                  },
                                },
                                popper: {
                                  sx: {
                                    "& .MuiTooltip-tooltip": {
                                      bgcolor: "var(--color-white) !important",
                                      backgroundColor: "var(--color-white) !important",
                                      // border: 'var(--space-1) solid var(--color-badge-grey-bg) !important',
                                      boxShadow: "var(--space-0) var(--space-4) var(--space-12) rgba(0, 0, 0, 0.1) !important",
                                    },
                                    "& .MuiTooltip-arrow": {
                                      color: "var(--color-white) !important",
                                      "&::before": {
                                        // border: 'var(--space-1) solid var(--color-badge-grey-bg) !important',
                                        backgroundColor: "var(--color-white) !important",
                                      },
                                    },
                                  },
                                },
                              }}
                            >
                              <span style={{ cursor: "pointer" }}>
                                <NewChip
                                  label={`+${item.add_secondary_tag.length - 2}`}
                                  shape="pill"
                                  size="md"
                                />
                              </span>
                            </Tooltip>
                          )}
                        </div>
                      ) : (
                        <span
                          style={{
                            backgroundColor: "var(--color-grey-100)",
                            border: "var(--space-1) solid var(--color-badge-grey-bg)",
                            fontSize: "var(--font-10)",
                            color: "var(--color-grey-600)",
                            padding: "var(--space-3) var(--space-5)",
                            borderRadius: "var(--radius-4)",
                            fontWeight: 'var(--font-weight-600)',
                          }}
                        >
                          N/A
                        </span>
                      )}
                    </div>

                    <div className="table-view-row">
                      <span className="" style={{ color: "var(--color-content-tertiary)" }}>
                        {item.ip_address || "N/A"}
                      </span>
                    </div>
                    <div className="table-view-row">
                      <span className="">
                        {item.status && item.status === "ONLINE" ? (
                          <NewChip
                            label={item.status}
                            shape="standard"
                            variant="success"
                          />
                        ) : (
                          <NewChip
                            label={item.status || "OFFLINE"}
                            shape="standard"
                            variant="warning"
                          />
                        )}
                      </span>
                    </div>
                    <div
                      className="table-view-row"
                      style={{
                        display: "flex",
                        flexDirection: "row",
                        alignItems: "center",
                        justifyContent: "end",
                        gap: "var(--space-6)",
                        padding: "var(--space-5) var(--space-7)",
                      }}
                    >
                      <Button
                        variant="outline"
                        className="btn btn-pagintaion font-weight-600"
                        style={{
                          padding: "var(--space-9)",
                        }}
                        isLoading={item.loading}
                        onClick={() => {
                          testConnectionApiHit(item, index);
                        }}
                      >
                        Test
                      </Button>

                      <button
                        className={classes.iconButton}
                        onClick={() => handleHealthDialogOpen(item.id)}
                      >
                        <span className="ri-heart-pulse-line font-22" />
                      </button>

                      <div
                        style={{
                          fontSize: "var(--font-11)",
                        }}
                      >
                        <PopoverDropdown
                          name={item.vm_name}
                          id={item.id}
                          handleOpenDialog={setDataforEdit}
                          handleRefresh={() => {
                            fetchVMsWithFilters(id, 1);
                          }}
                          handleOpenFetchKeyDialog={() =>
                            handleOpenFetchKeyDialog(
                              item.user_name,   // ← was item.vm_name
                              item.ip_address,
                            )
                          }
                          classes={classes}
                        />
                      </div>
                    </div>
                  </React.Fragment>
                );
              })}
            </div>

            <div
              style={{
                position: "relative",
                bottom: "0",
                marginBottom: "var(--space-23)",
                width: "100%",
              }}
            >
              {state.vm_arr && state.vm_arr.length > 0 && (
                <div style={{ marginTop: "var(--space-24)" }}>
                  <PaginationTwo
                    current_page_count={state.curr_page}
                    total_count={state.total_page}
                    next={state.next}
                    count={state.count}
                    previous={state.previous}
                    on_previous_click={() => {
                      fetchPrevInfo(null, state.previous);
                    }}
                    on_next_click={() => {
                      fetchNextInfo(null, state.next);
                    }}
                    on_pageNumber_click={(pageNumber) => {
                      fetchPageInfo(pageNumber);
                    }}
                  />
                </div>
              )}
            </div>
          </div>
        )}

        <AddSingleVMDialog
          open={open.open}
          handleClose={handleClickClose}
          sendDataToParent={getDataAndSetToState}
          edit_id={editedItem}
          user_name={fetchKeyDialogState.user_name}   // ← was vm_name
          ip_address={fetchKeyDialogState.ip_address}
          prev_state={state.singleVmChildState}
          clear_form_flag={open.clear_form_flag}
          vmGroupDetails={state.parent_state}
          handleCloseDialogAndFetchVMs={handleCloseDialogAndFetchVMs}
          onClickOpenSSHkeyDialog={handleClickSSHKeyDialog}
          clearFormFlag={open.clear_form_flag}
        />

        <AddVirtualMachineCSV
          open={openCSVDialog}
          vmGroupId={id}
          handleClose={() => setOpenCSVDialog(false)}
          handleCloseDialogAndFetchVMs={() => {
            setOpenCSVDialog(false);
            fetchVMsWithFilters(id, 1);
          }}
        />


        <Box sx={{
          border: 'none',
          '& > div > div': {
            border: 'none !important',
            boxShadow: 'none !important'
          },

          '& [class^="makeStyles-cardFooter-"]': {
            border: 'none !important',
            backgroundColor: 'transparent !important',
            padding: 'var(--space-16) var(--space-20) !important',
            display: 'flex !important',
            justifyContent: 'space-between !important',
            alignItems: 'center !important',
            position: 'relative !important',

            '& .footer-left': {
              display: 'flex !important',
              alignItems: 'center !important',
              gap: 'var(--space-12) !important'
            },

            '& .footer-right': {
              display: 'flex !important',
              gap: 'var(--space-12) !important',
              alignItems: 'center !important'
            },
          },
        }}
        >
          {taskId && (
            <ShowActivityStatusFramework
              open={taskId ? true : false}
              task_id={taskId}
              handleClose={handleCloseStatusActivity}
            />
          )}
        </Box>

        <VMSetHealthDialog
          open={openHealthDialog}
          vmSetId={selectedVMForHealth}
          onClose={handleHealthDialogClose}
        />

        {fetchKeyDialogState.open && (
          <FetchPublicKeyDialog
            user_name={fetchKeyDialogState.user_name}   // ← was vm_name
            ip_address={fetchKeyDialogState.ip_address}
            open={fetchKeyDialogState.open}
            onClose={handleCloseFetchKeyDialog}
          />
        )}
      </>
    </div>
  );
}
