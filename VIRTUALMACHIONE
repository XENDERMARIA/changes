          setState((prevState) => ({
            ...prevState,
            moreAdvFilterList: safeUpdatedList,
          }));
        }
      } else {
        // Map unique IDs to filter keys
        const idToKeyMap = {
          vm_name_adv_1: "vm_name",
          primary_tag_adv_2: "primary_tag",
          secondary_tag_adv_3: "secondary_tag",
          ip_address_adv_4: "ip_address",
          status_adv_5: "status",
        };

        updatedKey = idToKeyMap[uniqueId];

        if (!updatedKey) {
          console.warn(`Unknown filter ID: ${uniqueId}`);
          return;
        }

        setState((prevState) => ({
          ...prevState,
          advFilters: {
            ...prevState.advFilters,
            [updatedKey]: safeUpdatedList,
          },
        }));

        addFiltersToUrl(updatedKey, safeUpdatedList);
        const advFilters = {
          ...state.advFilters,
          [updatedKey]: safeUpdatedList,
        };

        if (id) {
          fetchVMsWithFilters(id, 1, advFilters);
