    try {
      if (!data?.id || index < 0 || index >= state.vm_arr.length) {
        console.error("Invalid data or index for test connection");
        return;
      }

      const updatedVmArr = [...state.vm_arr];
      updatedVmArr[index] = { ...updatedVmArr[index], loading: true };
      setState({ ...state, vm_arr: updatedVmArr });

      const post_url = GenerateURL(
        { edit_id: data.id },
        properties.api.edit_single_vm,
      );
      showSnackbar("info", "Testing connection to virtual machine...");
      PostData(post_url, data, (res) => onSaveSuccess(res, index), (err) => onSaveFail(err, index));
    } catch (error) {
      console.error("Error in test connection:", error);
      showSnackbar("error", "Failed to test connection", error?.message);
    }
  };

