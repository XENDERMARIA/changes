    try {
      return safeArray(data)
        .map((item) => ({
          label: item?.vm_name || "Unknown",
          value: item?.vm_name || "",
          ...item,
        }))
        .filter((item) => item.value);
    } catch (error) {
      console.error("Error parsing VM names:", error);
      return [];
    }
  }

  function filterDataParseForTags(data, tagType) {
    try {
      const tags_list = [];
      safeArray(data).forEach((item) => {
        const tagsArray =
          tagType === "primary"
            ? safeArray(item?.add_primary_tag)
            : safeArray(item?.add_secondary_tag);

        tagsArray.forEach((tag) => {
          if (tag && !tags_list.includes(tag)) {
            tags_list.push(tag);
          }
        });
      });

      return tags_list.map((item) => ({
        label: item,
        value: item,
      }));
    } catch (error) {
      console.error("Error parsing tags:", error);
      return [];
    }
  }

