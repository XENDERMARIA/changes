@keyframes blink-radient {
  0% {
    background: none;
  }

  20% {
    background: none;
  }

  25% {
    background: radial-gradient(circle, var(--color-info-400) 0%, var(--color-info-400) 20%, var(--color-info-400) 30%, rgba(255, 255, 255, 0.7) 40%, transparent 45%, transparent 80%, transparent 100%);
  }

  30% {
    background: radial-gradient(circle, var(--color-info-400) 0%, var(--color-info-400) 20%, var(--color-info-400) 30%, rgba(255, 255, 255, 0.7) 40%, transparent 45%, transparent 80%, transparent 100%);
  }

  35% {
    background: radial-gradient(circle, var(--color-info-400) 0%, var(--color-info-400) 20%, var(--color-info-400) 30%, rgba(255, 255, 255, 0.7) 50%, transparent 55%, transparent 80%, transparent 100%);
  }

  40% {
    background: radial-gradient(circle, var(--color-info-400) 0%, var(--color-info-400) 40%, var(--color-info-400) 50%, rgba(255, 255, 255, 0.7) 80%, rgba(255, 255, 255, 0.7) 100%);
  }

  50% {
    background: radial-gradient(circle, var(--color-info-400) 0%, var(--color-info-400) 40%, var(--color-info-400) 50%, rgba(255, 255, 255, 0.7) 80%, rgba(255, 255, 255, 0.7) 100%);
  }

  60% {
    background: radial-gradient(circle, var(--color-info-400) 0%, var(--color-info-400) 40%, var(--color-info-400) 50%, rgba(255, 255, 255, 0.7) 80%, rgba(255, 255, 255, 0.7) 100%);
  }

  65% {
    background: radial-gradient(circle, var(--color-info-400) 0%, var(--color-info-400) 40%, var(--color-info-400) 50%, rgba(255, 255, 255, 0.7) 80%, rgba(255, 255, 255, 0.7) 100%);
  }

  70% {
    background: radial-gradient(circle, var(--color-info-400) 0%, var(--color-info-400) 20%, var(--color-info-400) 30%, rgba(255, 255, 255, 0.7) 50%, transparent 55%, transparent 80%, transparent 100%);
  }

  75% {
