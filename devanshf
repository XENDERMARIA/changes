      // Calculate the difference in milliseconds
      const timeDifference = endDate - currentDate;
      let daysDifference = timeDifference / (1000 * 60 * 60 * 24);
      if (daysDifference < 0) {
        return daysDifference
      }
      if (daysDifference < 1) {
        daysDifference = 0
      }
      else {
        daysDifference = Math.ceil(daysDifference)
