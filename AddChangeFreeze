    function getProjectEnvList(master_env) {
        try {
            if (!state.env_data_map || !state.env_data_map[master_env]) {
                console.error("env_data_map or master_env not found:", {
                    env_data_map: state.env_data_map,
                    master_env
                });
                return [];
            }

            const arr = [];
            const env_names = Object.keys(state.env_data_map[master_env]);

            env_names.forEach((item) => {
                if (state.env_data_map[master_env][item] &&
                    state.env_data_map[master_env][item].id) {
                    arr.push({
                        id: state.env_data_map[master_env][item].id,
                        label: item
                    });
