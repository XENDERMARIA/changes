    function fetchFreezeDetails() {
        const requestInfo = {
            endPoint: GenerateURL(
                { freeze_id: freeze_id },
                properties.api.single_freeze_details
            ),
            httpMethod: "GET",
            httpHeaders: { "Content-Type": "application/json" },
        };

        setState((new_state) => ({
            ...new_state,
            data_loading: true,
            error_loading_data: null,
        }));

        InvokeApi(
            requestInfo,
            fetchFreezeDetailsSuccess,
            handleFetchFreezeDetailsFailed
        );
    }

    function fetchFreezeDetailsSuccess(response) {
        try {
            const daysObject = response.days
                ? getDaysObjectInCaseOfEdit(response.days)
                : {};

            const appKeys = Object.keys(response.entities).map(Number);
            const app_id = appKeys[0];

            const newStateData = {
                ...state.data,
                name: response.name,
                end_date: response.end_date,
                start_date: response.start_date,
                start_time: response.start_time,
                end_time: response.end_time,
                freeze_type: response.days
                    ? "Repeating & Window based"
                    : "Onetime Continuous",
                days_type: daysObject?.days_type || state.data.days_type,
                entity_type: "micro_service",
                entity_action: response.entity_action || "deploy",
                timezone: response.timezone || null,
                applications: appKeys,
            };

            const extraState = {
                selected_app_ids: appKeys,
                selected_master_env_list: response.entities[app_id]?.environment_master || [],
                selected_project_envs: response.entities[app_id]?.project_environment || [],
                selected_services: response.entities[app_id]?.service || [],
                selected_days: daysObject?.selected_days,
                error_loading_data: null,
            };

            setState((prev_state) => ({
                ...prev_state,
                ...extraState,
                data: newStateData,
            }));
        } catch (error) {
            console.error("Error processing freeze details:", error);
            handleFetchFreezeDetailsFailed("Failed to process freeze details");
        }
    }

    function getDaysObjectInCaseOfEdit(daysArray) {
        if (!Array.isArray(daysArray)) return {};

        const weekends = ["Saturday", "Sunday"];
        const weekdays = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];

        const dayLabelMap = {
            Monday: "M",
            Tuesday: "T",
            Wednesday: "W",
            Thursday: "T",
            Friday: "F",
            Saturday: "S",
            Sunday: "S",
        };

        const sortedInput = [...daysArray].sort((a, b) => a.localeCompare(b));
        const sortedWeekends = [...weekends].sort((a, b) => a.localeCompare(b));
        const sortedWeekdays = [...weekdays].sort((a, b) => a.localeCompare(b));

        let days_type;
        let days;

        if (
            sortedInput.length === sortedWeekends.length &&
            sortedInput.every((day, idx) => day === sortedWeekends[idx])
        ) {
            days_type = "Weekends";
            days = weekends;
        } else if (
            sortedInput.length === sortedWeekdays.length &&
            sortedInput.every((day, idx) => day === sortedWeekdays[idx])
        ) {
            days_type = "Weekdays";
            days = weekdays;
        } else {
            days_type = "Custom days";
            days = daysArray;
        }

        const selected_days = days.map((day) => ({
            id: day,
            label: dayLabelMap[day] || "",
        }));

        return {
            days_type,
            selected_days,
        };
    }

    function handleFetchFreezeDetailsFailed(error) {
        console.error("Freeze details fetch failed:", error);
