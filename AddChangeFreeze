            start_time: [VALIDATION_TYPE_REQUIRED],
            end_time: [VALIDATION_TYPE_REQUIRED],
            start_date: state.edit_start_date ? [VALIDATION_TYPE_REQUIRED] : [],
            end_date: state.edit_end_date ? [VALIDATION_TYPE_REQUIRED] : [],
        };

