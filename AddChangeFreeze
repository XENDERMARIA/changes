            project_environment: state.data.project_envs,
            service: state.data.service,
        };
        return obj;
    }

    function getEntitiesDataForMultipleApplication() {
        let obj = {};
        state.data.applications.forEach((item) => {
            obj[item] = {
                environment_master: [],
                project_environment: null,
                service: null,
            };
        });
        state.data.master_env.forEach((item) => {
            Object.keys(obj).forEach((app) => {
                obj[app].environment_master.push(item);
            });
        });
        return obj;
    }

