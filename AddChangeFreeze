            ...specificValidations,
            ...commonValidations,
        });

        if (!result.valid) {
            setState((prev_state) => ({
                ...prev_state,
                error: result.error,
            }));
            showSnackbar("error", "Please fill all the required details");
            return;
        }

        const post_data = {
            name: state.data.name,
            start_date:
                state.data.freeze_type === "Onetime Continuous"
                    ? state.data.start_date
                    : state.data.start_date || getTodayDate(),
            entities:
