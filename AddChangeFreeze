    function validateAndSaveData() {
        const post_url = freeze_id
            ? GenerateURL({ freeze_id: freeze_id }, properties.api.single_freeze_details)
            : GenerateURL({}, properties.api.save_change_freeze);

        const commonValidations = {
            name: [VALIDATION_TYPE_REQUIRED],
            applications: [VALIDATION_TYPE_REQUIRED],
            master_env: [VALIDATION_TYPE_REQUIRED],
            project_envs:
                state.data.applications.length > 1 || state.data.master_env.length > 1
                    ? []
