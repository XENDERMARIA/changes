    function fetchEnvListSuccess(response) {
        try {
            if (!response || !response.results) {
                throw new Error("Invalid response format");
            }

            let environment_master_list = [];
            let env_data_map = {};

            response.results.forEach((item) => {
                const isDuplicate = environment_master_list.some(
                    (existing) => existing.label === item.environment_master.name
                );

                if (!isDuplicate) {
                    environment_master_list.push({
                        id: item.environment_master.id,
                        label: item.environment_master.name,
                    });
                }

                let env_master_id = item.environment_master.id;
                env_data_map[env_master_id] = {
                    ...env_data_map[env_master_id],
                    [item.name]: {
                        id: item.id,
                        service_name_list: item.component_name_list,
                    },
                };
            });

            setState((new_state) => ({
                ...new_state,
                environment_master_list: environment_master_list,
                env_data_map: env_data_map,
                enable_master_env_input: true,
                data_loading: false,
                error_loading_data: null,
            }));

            if (state.selected_master_env_list && state.selected_master_env_list.length > 0) {
                setMasterEnvs(environment_master_list);
            }
        } catch (error) {
            console.error("Error processing environment data:", error);
            fetchEnvListFailed(error);
        }
    }

