    function checkIfIncluded(day) {
        if (!state?.selected_days) return false;
        return state.selected_days.some(item => item.id === day.id);
    }

    function handleSelectDay(selectedDay) {
        const currentSelected = [...state.selected_days];
        const dayIndex = currentSelected.findIndex(
            (day) => day.id === selectedDay.id
        );

        let newSelected;
        let newDaysType;

        if (dayIndex === -1) {
            newSelected = [...currentSelected, selectedDay].sort((a, b) => {
                const dayOrder = [
                    "Monday",
                    "Tuesday",
                    "Wednesday",
                    "Thursday",
                    "Friday",
                    "Saturday",
                    "Sunday",
                ];
                return dayOrder.indexOf(a.id) - dayOrder.indexOf(b.id);
            });
        } else {
            newSelected = currentSelected.filter((day) => day.id !== selectedDay.id);
        }

        if (newSelected.length === 0) {
            newDaysType = "Custom days";
        } else if (isWeekdays(newSelected)) {
            newDaysType = "Weekdays";
        } else if (isWeekends(newSelected)) {
            newDaysType = "Weekends";
        } else {
            newDaysType = "Custom days";
        }

        setState((new_state) => ({
            ...new_state,
            selected_days: newSelected,
            data: {
                ...new_state.data,
                days_type: newDaysType,
            },
        }));
    }

    function isWeekdays(days) {
        const weekdays = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];
        const selectedIds = days.map((day) => day.id).sort((a, b) => a.localeCompare(b));
        const weekdaysSorted = [...weekdays].sort((a, b) => a.localeCompare(b));

        return (
            selectedIds.length === weekdays.length &&
            JSON.stringify(selectedIds) === JSON.stringify(weekdaysSorted)
        );
    }

    function isWeekends(days) {
        const weekends = ["Saturday", "Sunday"];
        const selectedIds = days.map((day) => day.id).sort((a, b) => a.localeCompare(b));
        const weekendsSorted = [...weekends].sort((a, b) => a.localeCompare(b));

        return (
            selectedIds.length === weekends.length &&
            JSON.stringify(selectedIds) === JSON.stringify(weekendsSorted)
        );
    }

