                    ...new_state,
                    service_list: [],
                    data_loading: false,
                    error_loading_data: "Environment data not available",
                }));
                showSnackbar("error", "Environment data not available");
                return;
            }

            let services;
            const sub_env_list = Object.keys(state.env_data_map[master_env]);

            sub_env_list.forEach((item) => {
                if (state.env_data_map[master_env][item] &&
                    state.env_data_map[master_env][item].id === project_env) {
                    services = state.env_data_map[master_env][item].service_name_list;
                }
            });

            if (!services || services.length === 0) {
                setState((new_state) => ({
                    ...new_state,
                    service_list: [],
                    data_loading: false,
                    error_loading_data: null, // Don't show error for empty services
                }));
                return;
            }

            const updated_list = services.map(item => ({ id: item, label: item }));

            setState((new_state) => ({
                ...new_state,
                service_list: updated_list,
                data_loading: false,
                error_loading_data: null,
            }));
