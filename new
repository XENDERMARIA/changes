function getHostMappingList(hostMappingData) {
    var hostMappingList = {};
    var count = 1;
    var child_inherits = {};

    if (hostMappingData && Array.isArray(hostMappingData)) {
        hostMappingData.forEach(hostMapping => {
            hostMappingList = {
                ...hostMappingList,
                [count]: {
                    data: {
                        ip_address: hostMapping.ip_address || "",
                        host_alias: Array.isArray(hostMapping.host_alias)
                            ? hostMapping.host_alias
                            : [hostMapping.host_alias]
                    },
                    error: {},
                    validations: {}
                }
            };
            child_inherits = { ...child_inherits, [count++]: { view_mode: false } };
        });
    }

    return { ...hostMappingList, child_inherits: child_inherits };
}

const getIngressListAndDeleteIds = (data) => {
    var final_arr = [];
    if (data && data.length > 0) {
        data.forEach(item => {
            if (item['id']) {
                delete item['id']
            }
            if (item['updated_at']) {
                delete item['updated_at']
            }
            if (item['created_at']) {
                delete item['created_at']
            }
            final_arr.push(item);
        })
    }
    return final_arr
}

export function getSelectedEnv(id, data) {
    var selectedEnv = {};
    data.forEach(env => {
        if (env.id == id) {
            selectedEnv = { ...env }
        }
    })
    return selectedEnv; 
}

